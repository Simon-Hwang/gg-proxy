# gg-relay environment template (Plan 5 Task 7)
#
# Copy to `.env` and edit. Every field is prefixed with ``RELAY_`` because
# pydantic-settings reads from that namespace. Values shown below are the
# in-code defaults — uncommenting without changing has no effect.
#
# Quick start (dev):
#     cp .env.example .env
#     # uncomment the dev block at the bottom, fill RELAY_API_KEYS_RAW, run
#     #     gg-relay check-secrets
#     # then
#     #     gg-relay migrate && gg-relay serve
#
# Production checklist:
#     - RELAY_API_KEYS_RAW (comma-separated)
#     - RELAY_PUBLIC_BASE_URL
#     - RELAY_DASHBOARD_ADMIN_PASSWORD
#     - RELAY_DASHBOARD_SESSION_SECRET (>= 32 chars random)
#
# Anything marked ``# secret`` MUST be stored in your secret manager
# (Vault / SSM / Kubernetes Secret) — never commit a populated copy.

# ── core API ──────────────────────────────────────────────────────────
# Comma-separated API keys recognised on X-API-Key. Generate with:
#     openssl rand -hex 24
# secret
RELAY_API_KEYS_RAW=

# Externally-reachable base URL used in IM card callbacks. Must NOT end
# with a trailing slash.
RELAY_PUBLIC_BASE_URL=

# ── persistence ───────────────────────────────────────────────────────
# Default: SQLite file relative to CWD. For prod use Postgres:
#     postgresql+asyncpg://user:pw@host:5432/gg_relay
RELAY_DATABASE_URL=sqlite+aiosqlite:///./relay.db

# ── secrets fail-fast (Plan 7 Task 11 / D7.14) ────────────────────────
# When ``true`` the lifespan refuses to boot unless ALL of the
# following are set: RELAY_API_KEYS_RAW, a non-sqlite RELAY_DATABASE_URL,
# and (if ANY Feishu credential is set) the full Feishu triad
# (app id + app secret + webhook secret). When ``false`` (default,
# dev mode) the lifespan emits warnings but starts anyway.
RELAY_PRODUCTION_MODE=false

# Dev-only escape hatch — silences the "no API keys configured"
# warning for unit-test sandboxes that intentionally leave
# RELAY_API_KEYS_RAW empty. Has NO effect when RELAY_PRODUCTION_MODE=true.
RELAY_ALLOW_NO_KEYS=false

# ── plugin assembler ──────────────────────────────────────────────────
# Where gg-plugins is checked out / installed.
RELAY_GG_PLUGINS_HOME=/opt/gg-plugins
# Root directory for per-session plugin installs. Will hold per-session
# subdirs containing `install.sh` output and CLAUDE_ROOT.
RELAY_INSTALL_DIR_ROOT=/var/lib/gg-relay/installs

# ── docker backend ────────────────────────────────────────────────────
# Image used by the DockerExecutor (Plan 4+). The runner image MUST
# contain Node, claude-cli, and gg-plugins; see deploy/docker/ for the
# split between this runner image and the service image (which does NOT
# bundle those).
RELAY_DOCKER_IMAGE=ghcr.io/gg-org/gg-relay-runner:latest
# Per-session unix socket directory mounted into runner containers.
RELAY_DOCKER_SOCKET_ROOT=/var/run/gg-relay

# ── outbound proxy ────────────────────────────────────────────────────
# When unset, the lifespan starts a built-in MinimalProxy on $RELAY_PROXY_PORT.
# Set this to an external proxy URL (e.g. http://proxy:3128) to skip the
# built-in proxy and let runners use the supplied one instead.
# RELAY_OUTBOUND_PROXY_URL=
RELAY_PROXY_PORT=8888
RELAY_PROXY_AUDIT_LOG=/var/log/gg-relay/proxy-audit.jsonl

# ── session manager ───────────────────────────────────────────────────
# Hard wall-clock timeout per session (seconds). Plan 5 default 30 min.
RELAY_DEFAULT_TIMEOUT_S=1800
# Maximum concurrent in-flight sessions per service instance.
RELAY_MAX_CONCURRENT=10
# Optional override of RELAY_MAX_CONCURRENT for Plan 6 pause/resume
# tuning. Leave unset to inherit RELAY_MAX_CONCURRENT.
# RELAY_MAX_CONCURRENT_SESSIONS=10
# Grace period after timeout/interrupt before force-cancel (seconds).
RELAY_GRACE_PERIOD_S=30

# ── pause/resume (Plan 6) ─────────────────────────────────────────────
# How long a session may stay PAUSED before the watchdog cancels it
# (seconds). 30 minutes by default — matches RELAY_DEFAULT_TIMEOUT_S.
RELAY_PAUSED_TIMEOUT_S=1800
# Global cap on simultaneously-PAUSED sessions. Exceeding it returns
# HTTP 429 with Retry-After.
RELAY_MAX_PAUSED=50
# Per-X-API-Key cap on simultaneously-PAUSED sessions.
RELAY_MAX_PAUSED_PER_API_KEY=20
# Seconds resume() waits to re-acquire a semaphore slot before
# raising ResumeQueueTimeout (HTTP 429 with Retry-After).
RELAY_RESUME_TIMEOUT_S=60

# ── OpenTelemetry ─────────────────────────────────────────────────────
# Unset = no exporter (logs only). Set to an OTLP endpoint to ship traces.
# RELAY_OTEL_ENDPOINT=http://otel-collector:4317
RELAY_OTEL_EXPORTER=grpc

# ── IM (Feishu) ───────────────────────────────────────────────────────
# All four must be set together to enable Feishu HITL cards. Leave unset
# to disable the integration entirely (HITL still works via REST).
# secret
# RELAY_FEISHU_APP_ID=
# secret
# RELAY_FEISHU_APP_SECRET=
# secret
# RELAY_FEISHU_WEBHOOK_SECRET=
# RELAY_FEISHU_TARGET_CHAT_ID=

# ── redaction ─────────────────────────────────────────────────────────
# Extra regex patterns appended to the built-in RedactionEngine list.
# Comma-separated. Example: ".+@example\\.com,internal-id-\\d+"
RELAY_REDACTION_PATTERNS_RAW=
# Extra dict-key names treated as sensitive (comma-separated).
# Example: "ssn,internal_token,billing_account"
RELAY_REDACTION_KEYS_RAW=

# ── dashboard ─────────────────────────────────────────────────────────
# Required in production. Without these the dashboard refuses to start.
# secret
# RELAY_DASHBOARD_ADMIN_PASSWORD=
# secret — random 32+ char value for cookie signing
# RELAY_DASHBOARD_SESSION_SECRET=
# Chart.js CDN (Plan 6 D6.5=A). Override for unpkg / privately mirrored.
RELAY_CHART_JS_CDN=https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js
# Set to true to refuse fetching from non-/dashboard/static/ URLs
# (air-gapped deployments — see config.py docstring).
RELAY_CHART_JS_OFFLINE=false
# Cards per kanban page before HTMX revealed-trigger loads the next batch.
RELAY_KANBAN_DEFAULT_PAGE_SIZE=50
# Jaeger UI base URL for the per-session span-tree iframe (Plan 6 D6.6).
# Production deployments should set this to "/jaeger" and serve the
# Jaeger UI through the nginx reverse proxy (deploy/nginx/jaeger-proxy.conf)
# so X-Frame-Options doesn't block the iframe. Leave unset to disable
# the iframe and fall back to a plain trace-id readout.
# RELAY_JAEGER_UI_URL=/jaeger

# ── rate limit (Plan 7 D7.7+D7.8) ─────────────────────────────────────
# Per-API-key token bucket. Disable in dev if testing burst workloads.
RELAY_RATE_LIMIT_ENABLED=true
# Sustained refill rate (requests per minute per API key).
RELAY_RATE_LIMIT_PER_MIN=60
# Maximum burst above the sustained rate. Matches per-min so a fresh
# key starts with a full bucket sized to one minute.
RELAY_RATE_LIMIT_BURST=60
# In-process LRU cap on the bucket table; LRU evict on overflow,
# `_locks` cleaned in sync to prevent leak.
RELAY_RATE_LIMIT_LRU_CAP=10000
# Idle TTL (seconds) after which a bucket is reaped by the sweeper.
RELAY_RATE_LIMIT_TTL_S=3600

# ── Plan 8 D8.10 Postgres pool tuning ─────────────────────────────────
# Pool size per worker (SQLAlchemy ``pool_size``). Multiply by
# ``--workers`` and ensure
#     workers × (RELAY_DB_POOL_SIZE + RELAY_DB_MAX_OVERFLOW)
#         ≤ postgres.max_connections
# See docs/team-deployment.md for the worked example.
RELAY_DB_POOL_SIZE=10
# Extra connections SQLAlchemy may open above ``pool_size`` when the
# base pool is saturated, before queueing waiters.
RELAY_DB_MAX_OVERFLOW=5
# Cheap ``SELECT 1`` round-trip on checkout to catch dead TCP sessions
# before the engine hands them to the caller. Strongly recommended in
# production behind any kind of load balancer / connection-pooler.
RELAY_DB_POOL_PRE_PING=true
# Seconds after which an idle pooled connection is force-recycled.
# Defends against Postgres ``idle_in_transaction_session_timeout`` and
# load-balancer keepalives (1 hour default).
RELAY_DB_POOL_RECYCLE=3600
# Slow-query log threshold in milliseconds. Set to ``0`` or any
# negative value to disable the SQLAlchemy event listener entirely.
RELAY_DB_SLOW_QUERY_LOG_MS=500

# ── Plan 8 D8.1+D8.2 backend selectors (optional multi-worker tier) ──
# Default ``inmemory`` keeps the single-worker tier free of Redis. Set
# to ``redis`` only when running multiple uvicorn workers behind a
# load balancer — and then RELAY_REDIS_URL must be set too. The
# ``[redis]`` extra was reinstated in Plan 8 (Plan 5 D5.15 deletion
# reversed) — install via ``uv sync --extra redis``.
RELAY_EVENT_BUS_BACKEND=inmemory
RELAY_RATE_LIMIT_BACKEND=inmemory
# Required if EITHER backend above is ``redis``.
# RELAY_REDIS_URL=redis://localhost:6379/0
# Strict-backend mode (Plan 8 v2.1 MAJOR 4): when ``true`` and Redis
# is unreachable at startup, the lifespan aborts. When ``false``
# (default) it warns and falls back to inmemory — appropriate for a
# transient outage in single-worker deployments where the fallback
# is functionally identical to the configured baseline.
RELAY_STRICT_BACKEND=false

# ── Plan 9 v0.9.0-rc D9.11 — multi-worker deployment-mode check ─────
# Declares whether this gg-relay instance is part of a multi-worker
# cluster. Set to ``multi_worker`` when ``replicas > 1`` (helm /
# kubectl scale). The lifespan then validates that EVENT_BUS_BACKEND
# and RATE_LIMIT_BACKEND are cluster-safe (Redis) and REDIS_URL is
# configured. Single-worker mode (default) skips the check entirely
# — fully backward-compatible with every pre-v0.9.0-rc deployment.
RELAY_DEPLOYMENT_MODE=single_worker

# When ``true``, multi-worker config violations fail the lifespan
# (recommended for production). When ``false`` (default), violations
# log a warning and the boot continues — appropriate during the
# v0.9.0 → multi-worker migration window described in
# docs/cluster.md.
RELAY_DEPLOYMENT_MODE_STRICT=false

# ── Plan 8 D8.22 role mapping (api_key_label → role) ─────────────────
# Format: ``label=role`` tokens separated by ``,``. Valid roles are
# ``viewer`` / ``submitter`` / ``admin``. Tokens with any other role
# are dropped at boot with a warning. Empty (default) means every
# key falls back to ``viewer`` — in production a warning is emitted
# at boot because every mutation would 403.
# RELAY_ROLE_MAPPING_RAW=alice=admin,bob=submitter,carol=viewer
# Source-of-truth for role lookups (Plan 8 v2.3 BLOCKER 2):
#   * ``db``     (default) — runtime edits via dashboard /admin/keys
#                win; RELAY_ROLE_MAPPING_RAW is only the boot seed.
#   * ``config`` — RELAY_ROLE_MAPPING_RAW always wins; dashboard
#                  /admin/keys is read-only. Emergency lockdown only.
RELAY_ROLE_OVERRIDE_MODE=db

# ── Plan 8 D8.26 dashboard cookie users ──────────────────────────────
# Map ``dashboard_username → bcrypt_hash``. Mint a hash with:
#     python -c 'import bcrypt; print(bcrypt.hashpw(b"PW", bcrypt.gensalt()).decode())'
# Empty (default) disables cookie auth; the dashboard still works via
# RELAY_DASHBOARD_ADMIN_PASSWORD.
# RELAY_DASHBOARD_USERS_RAW=alice=$2b$12$<bcrypt>,bob=$2b$12$<bcrypt>

# ── Plan 8 D8.28 admin bootstrap ─────────────────────────────────────
# Expected api_key_label of the bootstrap admin. Plan 8 Task 3 seeds
# the role mapping so this label always resolves to ``admin`` even
# when RELAY_ROLE_MAPPING_RAW is empty — fresh deploys always have at
# least one operator capable of editing roles via /admin/keys.
RELAY_ADMIN_LABEL=admin

# ── Plan 8 D8.7 alert rules + Feishu @mention mapping ────────────────
# JSON object: ``{rule_name: [conditions]}``. Empty (default) uses the
# built-in defaults: fail-always, cancel-timeout-always, complete only
# when the session carries ``tag=notify``.
# RELAY_ALERT_RULES_JSON={"fail":["always"],"cancel":["timeout_recovered"],"complete":["tag=notify"]}
# Map ``api_key_label → Feishu open_id`` so alert cards can @mention
# the session owner. Unmapped owners fall back to a non-@-mention card.
# RELAY_FEISHU_USER_MAPPING_RAW=alice=ou_xxx,bob=ou_yyy

# ── integrations ──────────────────────────────────────────────────────
# JSONL location for gg.task-trace.v1 records consumed by gg-plugins
# `/gg:task-trace latest`. The default points at the per-user gg-plugins
# integration path. **Multi-instance hosts MUST set a unique path per
# instance** (e.g. /var/log/gg-relay/$HOSTNAME-trace.jsonl) or set the
# value to `none` to disable the writer — concurrent writes from
# multiple processes will interleave lines otherwise. See
# docs/deployment.md → "Task-trace JSONL".
RELAY_TASK_TRACE_PATH=~/.claude/metrics/gg-task-trace.jsonl
# Set to `none` to disable:
# RELAY_TASK_TRACE_PATH=none

# ── dev-mode overrides ────────────────────────────────────────────────
# Uncomment the block below for local development. Production deployments
# should NEVER use any of these values verbatim.
#
# RELAY_API_KEYS_RAW=dev-key-please-rotate
# RELAY_PUBLIC_BASE_URL=http://localhost:8000
# RELAY_DASHBOARD_ADMIN_PASSWORD=change-me
# RELAY_DASHBOARD_SESSION_SECRET=dev-session-secret-please-rotate-XXXXXX
# RELAY_DOCKER_IMAGE=gg-relay-runner:dev
# RELAY_OTEL_ENDPOINT=
